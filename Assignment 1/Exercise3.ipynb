    "def exact_solution(m, u_func):\n",
    "    h = 1/(m+1)\n",
    "    Ue = np.zeros(m*m)\n",
    "\n",
    "    for j in range(m):\n",
    "        for i in range(m):\n",
    "            x = (i+1)*h\n",
    "            y = (j+1)*h\n",
    "            Ue[i +j*m] = u_func(x, y)\n",
    "\n",
    "    return Ue"
   ]
