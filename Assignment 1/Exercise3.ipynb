    "def VCM(Amult, R, P, u, F, m):\n",
    "    h = 1/(m+1)\n",
    "    if m == 1:\n",
    "        u = -h**2/4*F\n",
    "    else:\n",
    "        u = smooth(u,omega,m,F) # nu_pre == 1\n",
    "        r = residual(F,u,m)\n",
    "        rc = coarsen(r, m)\n",
    "        ec = np.zeros_like(rc)\n",
    "        ec = VCM(Amult, R, P, ec, rc, m//2)\n",
    "        ef = interpolate(ec, m)\n",
    "        u = u + ef\n",
    "        u = smooth(u,omega,m,F)   # nu_post == 1\n",
    "    return u\n",
    "        \n",
    "def residual(U, F, m):\n",
    "    return F - Amult(U, m)\n"
   ]
