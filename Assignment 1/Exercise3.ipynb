    "def Amult_minus(U, m):\n",
    "    h = 1.0 / (m + 1)\n",
    "    AU = np.zeros_like(U)\n",
    "\n",
    "    for j in range(m):\n",
    "        for i in range(m):\n",
    "            k = i + j*m   # 2D -> 1D index\n",
    "            \n",
    "            center = 4 * U[k]\n",
    "            \n",
    "            left  = U[k-1]   if i > 0     else 0.0\n",
    "            right = U[k+1]   if i < m-1   else 0.0\n",
    "            down  = U[k-m]   if j > 0     else 0.0\n",
    "            up    = U[k+m]   if j < m-1   else 0.0\n",
    "            \n",
    "            AU[k] = (center - left - right - down - up) / h**2\n",
    "\n",
    "    return AU # this is actually -AU as required for cg"
   ]
  },
