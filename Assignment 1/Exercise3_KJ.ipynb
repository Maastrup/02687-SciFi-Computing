    "def Amult(U, m):\n",
    "    AU = np.pad(U.reshape((m, m)), ((1,1), (1,1)), 'constant')\n",
    "    AU[1:-1, 1:-1] = \\\n",
    "        AU[:-2, 1:-1] + \\\n",
    "        AU[1:-1, :-2] + \\\n",
    "        AU[2:, 1:-1] + \\\n",
    "        AU[1:-1, 2:] - \\\n",
    "        4 * AU[1:-1, 1:-1] \n",
    "    return - (1+m)**2 * AU[1:-1, 1:-1].reshape(-1)\n",
    "\n",
    "U = np.array([1,2,3,4])\n",
    "m = 2\n",
    "Amult(U, m)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "a4adb457",
   "metadata": {},
   "outputs": [],
   "source": [
    "def u_func(x,y):\n",
    "    return np.sin(4*np.pi*(x+y)) + np.cos(4*np.pi*x*y)\n",
    "\n",
    "def f_func(x,y):\n",
    "    term1 = -32*np.pi**2*np.sin(4*np.pi*(x+y))\n",
    "    term2 = -16*np.pi**2*(x**2 + y**2)*np.cos(4*np.pi*x*y)\n",
    "    return term1 + term2\n",
    "\n",
    "def form_rhs(m, f_func, u_func):\n",
    "\n",
    "    h = 1.0/(m+1)\n",
    "    b = np.zeros(m*m)\n",
    "\n",
    "    for j in range(1, m+1):\n",
    "        for i in range(1, m+1):\n",
    "\n",
    "            k = (j-1)*m + (i-1)\n",
    "            x = i*h\n",
    "            y = j*h\n",
    "\n",
    "            b[k] = f_func(x,y)\n",
    "\n",
    "            # left boundary\n",
    "            if i == 1:\n",
    "                b[k] -= u_func(0,y)/h**2\n",
    "\n",
    "            # right boundary\n",
    "            if i == m:\n",
    "                b[k] -= u_func(1,y)/h**2\n",
    "\n",
    "            # bottom boundary\n",
    "            if j == 1:\n",
    "                b[k] -= u_func(x,0)/h**2\n",
    "\n",
    "            # top boundary\n",
    "            if j == m:\n",
    "                b[k] -= u_func(x,1)/h**2\n",
    "\n",
    "    return b"
   ]
  },
